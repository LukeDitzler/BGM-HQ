import { useState, useEffect, useCallback } from "react";
import { createClient } from "@supabase/supabase-js";

const supabase = createClient(
  import.meta.env.VITE_SUPABASE_URL,
  import.meta.env.VITE_SUPABASE_ANON_KEY
);

// ── Config ────────────────────────────────────────────────────────────────────
const LEAGUE_IDS = {
  2024: "1099477523693473792",
  2025: "1182397104202231808",
  2026: "1314366510466076672",
};
const SLEEPER_USERNAME = "LukeWickham";
const CURRENT_YEAR = 2025;
const CURRENT_LEAGUE_ID = LEAGUE_IDS[CURRENT_YEAR];

// ── 2026 Rookie Draft — draft_order is confirmed and hardcoded here.
// Source: GET /v1/league/1314366510466076672/drafts
// draft_order maps Sleeper user_id (string) → draft slot (number)
// Type: linear (slot is the same every round — no snake reversal)
const DRAFT_2026_ORDER = {
  "1001761563709136896": 1,
  "1019643084038164480": 2,
  "475077924572098560":  3,
  "1098839783356416000": 4,
  "1103784251838902272": 5,
  "210554991725776896":  6,
  "1012978987339010048": 7,
  "1100172269831208960": 8,
  "1101182856459681792": 9,
  "736694658993917952":  10,
  "761283754764386304":  11,
  "1103781522043129856": 12,
};
// Utility: get slot for a user_id (string coercion safe)
function getDraftSlot(userId) {
  return DRAFT_2026_ORDER[String(userId)] ?? null;
}

// ── Design Tokens — BGM Light Mode, Logo Green #1a5c2a ───────────────────────
const C = {
  bg: "#f4f6f4",           // warm off-white background
  surface: "#ffffff",      // pure white cards
  surfaceHigh: "#eef2ee",  // slightly tinted surface
  border: "#d6e4d6",       // soft green-tinted border
  borderLight: "#e4ece4",  // lighter border variant
  text: "#0f2e15",         // near-black with green undertone
  muted: "#5a7a60",        // muted mid-green
  mutedLight: "#7a9a80",   // lighter muted
  accent: "#1a5c2a",       // BGM logo green
  accentDim: "#14471f",    // darker green for hover
  accentLight: "#e8f2e9",  // light green tint
  accentGlow: "rgba(26,92,42,0.08)",
  white: "#ffffff",
  green: "#1a7a32",        // positive / active
  red: "#c0392b",          // injury / negative
  blue: "#1a5c8a",         // informational
};

// ── Sleeper API helpers ───────────────────────────────────────────────────────
const SLEEPER = "https://api.sleeper.app/v1";

// noCache: true for roster/matchup data that changes frequently
// noCache: false (default) for large static data like /players/nfl
async function sleeperFetch(path, noCache = false) {
  const res = await fetch(`${SLEEPER}${path}`, noCache ? { cache: "no-store" } : {});
  if (!res.ok) throw new Error(`Sleeper API error: ${path}`);
  return res.json();
}

// ── Shared styles ─────────────────────────────────────────────────────────────
const card = {
  background: C.surface,
  border: `1px solid ${C.border}`,
  borderRadius: 4,
  padding: "20px 24px",
};

const statBox = {
  background: C.surfaceHigh,
  border: `1px solid ${C.border}`,
  borderRadius: 4,
  padding: "14px 18px",
};

const tabBtn = (active) => ({
  background: active ? C.accentLight : "transparent",
  border: "none",
  borderBottom: `2px solid ${active ? C.accent : "transparent"}`,
  color: active ? C.accent : C.muted,
  fontSize: 12,
  fontWeight: active ? 700 : 500,
  letterSpacing: "0.1em",
  textTransform: "uppercase",
  fontFamily: "'DM Mono', monospace",
  padding: "0 20px",
  height: 58,
  cursor: "pointer",
  transition: "all 0.15s",
  whiteSpace: "nowrap",
});

const badge = (color = C.accent) => ({
  display: "inline-block",
  background: `${color}22`,
  color: color,
  border: `1px solid ${color}44`,
  borderRadius: 3,
  fontSize: 10,
  fontWeight: 700,
  letterSpacing: "0.08em",
  padding: "2px 7px",
  fontFamily: "'DM Mono', monospace",
  textTransform: "uppercase",
});

const posColor = (pos) => {
  const map = { QB: "#f87171", RB: "#4ade80", WR: "#60a5fa", TE: "#fb923c", K: "#a78bfa", DEF: "#94a3b8", FLEX: C.accent };
  return map[pos] || C.muted;
};

// ── Auth Modal ────────────────────────────────────────────────────────────────
function AuthModal({ onClose }) {
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [error, setError] = useState("");
  const [loading, setLoading] = useState(false);

  const inp = {
    width: "100%", padding: "10px 14px", background: C.surfaceHigh,
    border: `1px solid ${C.border}`, borderRadius: 4, color: C.text,
    fontSize: 14, fontFamily: "'DM Mono', monospace", outline: "none",
    boxSizing: "border-box",
  };

  async function handleLogin(e) {
    e.preventDefault();
    setLoading(true); setError("");
    const { error } = await supabase.auth.signInWithPassword({ email, password });
    if (error) setError(error.message);
    else onClose();
    setLoading(false);
  }

  return (
    <div style={{ position: "fixed", inset: 0, background: "rgba(15,46,21,0.55)", backdropFilter: "blur(4px)", zIndex: 1000, display: "flex", alignItems: "center", justifyContent: "center" }}>
      <div style={{ background: C.white, border: `1px solid ${C.border}`, borderRadius: 6, padding: 40, width: 360, position: "relative", boxShadow: "0 8px 32px rgba(26,92,42,0.12)" }}>
        <button onClick={onClose} style={{ position: "absolute", top: 14, right: 18, background: "none", border: "none", color: C.muted, fontSize: 20, cursor: "pointer" }}>×</button>
        <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 22, fontWeight: 700, color: C.accent, letterSpacing: "0.05em", marginBottom: 6 }}>BIG GREEN MACHINE</div>
        <div style={{ fontSize: 12, color: C.muted, fontFamily: "'DM Mono', monospace", marginBottom: 28 }}>AUTHORIZED ACCESS ONLY</div>
        <form onSubmit={handleLogin} style={{ display: "flex", flexDirection: "column", gap: 14 }}>
          <div>
            <div style={{ fontSize: 10, fontWeight: 700, color: C.muted, letterSpacing: "0.1em", textTransform: "uppercase", fontFamily: "'DM Mono', monospace", marginBottom: 6 }}>Email</div>
            <input style={inp} type="email" value={email} onChange={e => setEmail(e.target.value)} required autoFocus />
          </div>
          <div>
            <div style={{ fontSize: 10, fontWeight: 700, color: C.muted, letterSpacing: "0.1em", textTransform: "uppercase", fontFamily: "'DM Mono', monospace", marginBottom: 6 }}>Password</div>
            <input style={inp} type="password" value={password} onChange={e => setPassword(e.target.value)} required />
          </div>
          {error && <div style={{ color: C.red, fontSize: 12, fontFamily: "'DM Mono', monospace" }}>{error}</div>}
          <button type="submit" disabled={loading} style={{
            background: C.accent, color: C.white, border: "none", borderRadius: 4,
            padding: "11px", fontSize: 13, fontWeight: 700, cursor: "pointer",
            fontFamily: "'Barlow Condensed', sans-serif", letterSpacing: "0.1em",
            textTransform: "uppercase", marginTop: 6,
          }}>{loading ? "Signing in…" : "Enter HQ"}</button>
        </form>
      </div>
    </div>
  );
}

// ── Loading Spinner ───────────────────────────────────────────────────────────
function Spinner({ label = "Loading…" }) {
  return (
    <div style={{ display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", padding: "80px 0", gap: 16 }}>
      <div style={{ width: 32, height: 32, border: `2px solid ${C.border}`, borderTop: `2px solid ${C.accent}`, borderRadius: "50%", animation: "spin 0.8s linear infinite" }} />
      <div style={{ fontSize: 11, color: C.muted, fontFamily: "'DM Mono', monospace", letterSpacing: "0.1em" }}>{label}</div>
    </div>
  );
}

// ── HOME TAB ──────────────────────────────────────────────────────────────────
function HomeTab({ leagueData, rosters, users, myRoster, myUser, nflState }) {
  const [matchups, setMatchups] = useState([]);
  const [loadingMatchups, setLoadingMatchups] = useState(true);

  const week = nflState?.week || 1;
  const season = nflState?.season || CURRENT_YEAR;

  useEffect(() => {
    if (!week) return;
    sleeperFetch(`/league/${CURRENT_LEAGUE_ID}/matchups/${week}`, true)
      .then(setMatchups)
      .catch(() => setMatchups([]))
      .finally(() => setLoadingMatchups(false));
  }, [week]);

  if (!myRoster || !leagueData) return <Spinner label="Loading franchise data…" />;

  const myMatchup = matchups.find(m => m.roster_id === myRoster.roster_id);
  const opponentMatchup = myMatchup ? matchups.find(m => m.matchup_id === myMatchup.matchup_id && m.roster_id !== myRoster.roster_id) : null;
  const opponentRoster = opponentMatchup ? rosters.find(r => r.roster_id === opponentMatchup.roster_id) : null;
  const opponentUser = opponentRoster ? users.find(u => String(u.user_id) === String(opponentRoster.owner_id)) : null;

  const wins = myRoster.settings?.wins ?? 0;
  const losses = myRoster.settings?.losses ?? 0;
  const ties = myRoster.settings?.ties ?? 0;
  const pf = myRoster.settings?.fpts ? parseFloat(`${myRoster.settings.fpts}.${myRoster.settings.fpts_decimal ?? 0}`).toFixed(1) : "—";
  const pa = myRoster.settings?.fpts_against ? parseFloat(`${myRoster.settings.fpts_against}.${myRoster.settings.fpts_against_decimal ?? 0}`).toFixed(1) : "—";

  // Standings rank
  const sorted = [...rosters].sort((a, b) => {
    const wa = a.settings?.wins ?? 0, wb = b.settings?.wins ?? 0;
    if (wb !== wa) return wb - wa;
    const pfA = parseFloat(`${a.settings?.fpts ?? 0}.${a.settings?.fpts_decimal ?? 0}`);
    const pfB = parseFloat(`${b.settings?.fpts ?? 0}.${b.settings?.fpts_decimal ?? 0}`);
    return pfB - pfA;
  });
  const rank = sorted.findIndex(r => r.roster_id === myRoster.roster_id) + 1;
  const totalTeams = rosters.length;

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 24 }}>
      {/* Franchise header */}
      <div style={{ ...card, background: "linear-gradient(135deg, #f0f7f0 0%, #e4f0e5 100%)", borderColor: C.accentDim, position: "relative", overflow: "hidden" }}>
        <div style={{ position: "absolute", top: -40, right: -40, width: 200, height: 200, background: C.accentGlow, borderRadius: "50%", filter: "blur(60px)" }} />
        <div style={{ position: "relative" }}>
          <div style={{ fontSize: 11, fontFamily: "'DM Mono', monospace", color: C.accentDim, letterSpacing: "0.15em", textTransform: "uppercase", marginBottom: 8 }}>Dynasty Franchise · {season} Season</div>
          <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 42, fontWeight: 800, color: C.text, letterSpacing: "-0.01em", lineHeight: 1 }}>BIG GREEN MACHINE</div>
          <div style={{ fontSize: 13, color: C.muted, fontFamily: "'DM Mono', monospace", marginTop: 6 }}>{leagueData.name}</div>
          <div style={{ display: "flex", gap: 24, marginTop: 20, flexWrap: "wrap" }}>
            {[
              { label: "Record", value: ties > 0 ? `${wins}-${losses}-${ties}` : `${wins}-${losses}` },
              { label: "Points For", value: pf },
              { label: "Points Against", value: pa },
              { label: "League Rank", value: `#${rank} / ${totalTeams}` },
            ].map(({ label, value }) => (
              <div key={label}>
                <div style={{ fontSize: 10, fontFamily: "'DM Mono', monospace", color: C.muted, letterSpacing: "0.1em", textTransform: "uppercase" }}>{label}</div>
                <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 28, fontWeight: 700, color: C.accent, lineHeight: 1.2 }}>{value}</div>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Current matchup */}
      <div>
        <SectionHeader label={`Week ${week} Matchup`} />
        {loadingMatchups ? <Spinner label="Loading matchup…" /> : !myMatchup ? (
          <div style={{ ...statBox, color: C.muted, fontSize: 13, fontFamily: "'DM Mono', monospace" }}>No active matchup data.</div>
        ) : (
          <div style={{ ...card, display: "grid", gridTemplateColumns: "1fr auto 1fr", gap: 20, alignItems: "center" }}>
            <TeamMatchupSide user={myUser} roster={myRoster} matchup={myMatchup} align="left" isMe />
            <div style={{ textAlign: "center" }}>
              <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 11, color: C.muted, letterSpacing: "0.1em" }}>VS</div>
            </div>
            <TeamMatchupSide user={opponentUser} roster={opponentRoster} matchup={opponentMatchup} align="right" />
          </div>
        )}
      </div>

      {/* League standings snapshot */}
      <div>
        <SectionHeader label="League Standings" />
        <div style={{ ...card, padding: 0, overflow: "hidden" }}>
          <table style={{ width: "100%", borderCollapse: "collapse", fontFamily: "'DM Mono', monospace", fontSize: 12 }}>
            <thead>
              <tr style={{ borderBottom: `1px solid ${C.border}` }}>
                {["#", "Team", "W", "L", "PF", "PA"].map(h => (
                  <th key={h} style={{ padding: "10px 16px", color: C.muted, fontWeight: 600, letterSpacing: "0.08em", textAlign: h === "Team" ? "left" : "right", fontSize: 10, textTransform: "uppercase" }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {sorted.map((roster, i) => {
                const u = users.find(u => String(u.user_id) === String(roster.owner_id));
                const teamName = u?.metadata?.team_name || u?.display_name || "Unknown";
                const isMe = roster.roster_id === myRoster.roster_id;
                const rpf = parseFloat(`${roster.settings?.fpts ?? 0}.${roster.settings?.fpts_decimal ?? 0}`).toFixed(1);
                const rpa = parseFloat(`${roster.settings?.fpts_against ?? 0}.${roster.settings?.fpts_against_decimal ?? 0}`).toFixed(1);
                return (
                  <tr key={roster.roster_id} style={{ borderBottom: `1px solid ${C.border}`, background: isMe ? C.accentGlow : "transparent" }}>
                    <td style={{ padding: "9px 16px", color: C.muted, textAlign: "right" }}>{i + 1}</td>
                    <td style={{ padding: "9px 16px", color: isMe ? C.accent : C.text, fontWeight: isMe ? 700 : 400 }}>{teamName}{isMe && <span style={{ ...badge(), marginLeft: 8, fontSize: 9 }}>BGM</span>}</td>
                    <td style={{ padding: "9px 16px", color: C.green, textAlign: "right" }}>{roster.settings?.wins ?? 0}</td>
                    <td style={{ padding: "9px 16px", color: C.red, textAlign: "right" }}>{roster.settings?.losses ?? 0}</td>
                    <td style={{ padding: "9px 16px", color: C.text, textAlign: "right" }}>{rpf}</td>
                    <td style={{ padding: "9px 16px", color: C.muted, textAlign: "right" }}>{rpa}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}

function TeamMatchupSide({ user, roster, matchup, align, isMe }) {
  const teamName = user?.metadata?.team_name || user?.display_name || "Unknown";
  const pts = matchup ? parseFloat(`${matchup.points ?? 0}`).toFixed(2) : "—";
  return (
    <div style={{ textAlign: align }}>
      <div style={{ fontSize: 11, fontFamily: "'DM Mono', monospace", color: isMe ? C.accent : C.muted, letterSpacing: "0.08em", textTransform: "uppercase", marginBottom: 4 }}>{isMe ? "◆ YOUR TEAM" : "OPPONENT"}</div>
      <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 22, fontWeight: 700, color: C.text }}>{teamName}</div>
      <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 40, fontWeight: 800, color: isMe ? C.accent : C.text, lineHeight: 1.1 }}>{pts}</div>
      <div style={{ fontSize: 10, fontFamily: "'DM Mono', monospace", color: C.muted }}>pts</div>
    </div>
  );
}

// ── ROSTER TAB ────────────────────────────────────────────────────────────────
function RosterTab({ myRoster, allPlayers, fcPlayers, nflState, rosters, users }) {
  const [view, setView] = useState("starters");

  if (!myRoster || !allPlayers) return <Spinner label="Loading roster…" />;

  const starters = myRoster.starters || [];
  const allOnRoster = myRoster.players || [];
  const bench = allOnRoster.filter(id => !starters.includes(id));
  const taxi = myRoster.taxi || [];
  const ir = myRoster.reserve || [];

  const group = view === "starters" ? starters
    : view === "bench" ? bench
    : view === "taxi" ? taxi
    : ir;

  const enrichPlayer = (id, slotPos = null) => {
    const p = allPlayers[id];
    const fc = fcPlayers ? (fcPlayers[id] || null) : null;
    if (!p) return { id, name: id, pos: "?", team: "FA", age: "—", exp: "—", injStatus: null, slot: slotPos, fc: null };
    return {
      id,
      name: `${p.first_name || ""} ${p.last_name || ""}`.trim(),
      pos: p.position || "?",
      team: p.team || "FA",
      age: p.age || "—",
      exp: p.years_exp !== undefined ? p.years_exp : "—",
      injStatus: p.injury_status || null,
      slot: slotPos,
      college: p.college || "—",
      number: p.number,
      fc,  // { fcValue, fcOverallRank, fcPosRank, ... } or null
    };
  };

  const players = group.map((id, i) => enrichPlayer(id, view === "starters" ? id : null));
  const posOrder = ["QB", "RB", "WR", "TE", "K", "DEF"];
  const sorted = [...players].sort((a, b) => {
    const ai = posOrder.indexOf(a.pos), bi = posOrder.indexOf(b.pos);
    return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
  });

  const views = [
    { id: "starters", label: "Starters" },
    { id: "bench", label: "Bench" },
    { id: "taxi", label: "Taxi Squad" },
    { id: "ir", label: "IR" },
  ];

  // ── Roster strength summary ────────────────────────────────────────────────
  const allRosterPlayers = (myRoster.players || []).map(id => enrichPlayer(id));
  const starterEnriched = starters.map(id => enrichPlayer(id));
  const benchEnriched = (myRoster.players || []).filter(id => !starters.includes(id) && !(myRoster.taxi||[]).includes(id) && !(myRoster.reserve||[]).includes(id)).map(id => enrichPlayer(id));

  const avgFcValue = (arr) => {
    const withFc = arr.filter(p => p.fc?.fcValue);
    if (!withFc.length) return null;
    return Math.round(withFc.reduce((s, p) => s + p.fc.fcValue, 0) / withFc.length);
  };
  const totalFcValue = (arr) => {
    const withFc = arr.filter(p => p.fc?.fcValue);
    return withFc.reduce((s, p) => s + p.fc.fcValue, 0);
  };
  const topPosRank = (arr, pos) => {
    const p = arr.filter(p => p.pos === pos && p.fc).sort((a,b) => a.fc.fcPosRank - b.fc.fcPosRank)[0];
    return p ? `${p.fc.fcPos}${p.fc.fcPosRank}` : "—";
  };

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
      {/* Roster Strength Panel */}
      {fcPlayers && (
        <div style={{ ...card, background: C.surfaceHigh, borderColor: C.accentDim }}>
          <SectionHeader label="Roster Strength" />
          <div style={{ display: "flex", gap: 12, flexWrap: "wrap" }}>
            {[
              { label: "Starting Lineup Value", value: totalFcValue(starterEnriched).toLocaleString(), sub: `avg ${avgFcValue(starterEnriched)?.toLocaleString() ?? "—"} / starter` },
              { label: "Full Roster Value", value: totalFcValue(allRosterPlayers).toLocaleString(), sub: `${allRosterPlayers.filter(p=>p.fc).length} players ranked` },
              { label: "Best QB", value: topPosRank(allRosterPlayers, "QB"), sub: "FantasyCalc pos rank" },
              { label: "Best RB", value: topPosRank(allRosterPlayers, "RB"), sub: "FantasyCalc pos rank" },
              { label: "Best WR", value: topPosRank(allRosterPlayers, "WR"), sub: "FantasyCalc pos rank" },
              { label: "Best TE", value: topPosRank(allRosterPlayers, "TE"), sub: "FantasyCalc pos rank" },
            ].map(({ label, value, sub }) => (
              <div key={label} style={{ ...statBox, minWidth: 140, flex: 1 }}>
                <div style={{ fontSize: 9, fontFamily: "'DM Mono', monospace", color: C.muted, letterSpacing: "0.1em", textTransform: "uppercase", marginBottom: 4 }}>{label}</div>
                <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 24, fontWeight: 800, color: C.accent, lineHeight: 1 }}>{value}</div>
                <div style={{ fontSize: 9, fontFamily: "'DM Mono', monospace", color: C.muted, marginTop: 3 }}>{sub}</div>
              </div>
            ))}
          </div>
        </div>
      )}

      <div style={{ display: "flex", gap: 0, marginBottom: 0, borderBottom: `1px solid ${C.border}` }}>
        {views.map(v => (
          <button key={v.id} onClick={() => setView(v.id)} style={{
            background: "transparent", border: "none",
            borderBottom: `2px solid ${view === v.id ? C.accent : "transparent"}`,
            color: view === v.id ? C.accent : C.muted,
            fontFamily: "'DM Mono', monospace", fontSize: 11, fontWeight: 700,
            letterSpacing: "0.1em", textTransform: "uppercase",
            padding: "10px 18px", cursor: "pointer",
          }}>{v.label} <span style={{ color: C.muted, fontWeight: 400 }}>({
            v.id === "starters" ? starters.length
            : v.id === "bench" ? bench.length
            : v.id === "taxi" ? taxi.length
            : ir.length
          })</span></button>
        ))}
      </div>

      {sorted.length === 0 ? (
        <div style={{ ...statBox, color: C.muted, fontSize: 13, fontFamily: "'DM Mono', monospace" }}>No players in this group.</div>
      ) : (
        <div style={{ ...card, padding: 0, overflow: "hidden" }}>
          <table style={{ width: "100%", borderCollapse: "collapse", fontFamily: "'DM Mono', monospace", fontSize: 12 }}>
            <thead>
              <tr style={{ borderBottom: `1px solid ${C.border}` }}>
                {["Pos", "Player", "Team", "Age", "Exp", "FC Overall", "FC Pos Rank", "FC Value", "Status"].map(h => (
                  <th key={h} style={{ padding: "10px 16px", color: C.muted, fontWeight: 600, letterSpacing: "0.08em", textAlign: "left", fontSize: 10, textTransform: "uppercase" }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {sorted.map((p, i) => (
                <tr key={p.id} style={{ borderBottom: `1px solid ${C.border}`, transition: "background 0.1s" }}
                  onMouseEnter={e => e.currentTarget.style.background = C.surfaceHigh}
                  onMouseLeave={e => e.currentTarget.style.background = "transparent"}>
                  <td style={{ padding: "10px 16px" }}>
                    <span style={{ ...badge(posColor(p.pos)) }}>{p.pos}</span>
                  </td>
                  <td style={{ padding: "10px 16px", color: C.text, fontWeight: 600 }}>
                    {p.name}
                    {p.number && <span style={{ color: C.muted, fontWeight: 400, marginLeft: 6 }}>#{p.number}</span>}
                  </td>
                  <td style={{ padding: "10px 16px", color: C.mutedLight }}>{p.team}</td>
                  <td style={{ padding: "10px 16px", color: C.mutedLight }}>{p.age}</td>
                  <td style={{ padding: "10px 16px", color: p.exp === 0 ? C.green : C.mutedLight }}>
                    {p.exp === 0 ? "Rookie" : p.exp === "—" ? "—" : `Yr ${p.exp + 1}`}
                  </td>
                  <td style={{ padding: "10px 16px", color: p.fc ? C.text : C.muted, textAlign: "right", fontWeight: p.fc ? 600 : 400 }}>
                    {p.fc ? `#${p.fc.fcOverallRank}` : "—"}
                  </td>
                  <td style={{ padding: "10px 16px", color: p.fc ? posColor(p.pos) : C.muted, textAlign: "right", fontWeight: p.fc ? 600 : 400 }}>
                    {p.fc ? `${p.fc.fcPos}${p.fc.fcPosRank}` : "—"}
                  </td>
                  <td style={{ padding: "10px 16px", color: C.accent, textAlign: "right", fontWeight: 600 }}>
                    {p.fc ? p.fc.fcValue.toLocaleString() : "—"}
                  </td>
                  <td style={{ padding: "10px 16px" }}>
                    {p.injStatus ? (
                      <span style={{ ...badge(p.injStatus === "Out" || p.injStatus === "IR" ? C.red : C.accent) }}>{p.injStatus}</span>
                    ) : (
                      <span style={{ color: C.green, fontSize: 10, letterSpacing: "0.06em" }}>Active</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {/* Draft Capital — below roster table */}
      <div style={{ marginTop: 8 }}>
        <DraftCapitalPanel myRoster={myRoster} rosters={rosters} users={users} />
      </div>
    </div>
  );
}

// ── WATCH LIST TAB ────────────────────────────────────────────────────────────
function WatchListTab({ allPlayers, fcPlayers, myRoster }) {
  const [watchList, setWatchList] = useState(() => {
    try { return JSON.parse(localStorage.getItem("bgm_watchlist") || "[]"); } catch { return []; }
  });
  const [search, setSearch] = useState("");
  const [searchResults, setSearchResults] = useState([]);
  const [filter, setFilter] = useState("all");

  useEffect(() => {
    localStorage.setItem("bgm_watchlist", JSON.stringify(watchList));
  }, [watchList]);

  useEffect(() => {
    if (!search || !allPlayers) { setSearchResults([]); return; }
    const q = search.toLowerCase();
    const results = Object.entries(allPlayers)
      .filter(([, p]) => {
        const name = `${p.first_name || ""} ${p.last_name || ""}`.toLowerCase();
        return name.includes(q) && p.active;
      })
      .slice(0, 8)
      .map(([id, p]) => ({ id, ...p }));
    setSearchResults(results);
  }, [search, allPlayers]);

  const addToWatchList = (player, signal, note) => {
    if (watchList.find(w => w.id === player.id)) return;
    setWatchList(prev => [...prev, {
      id: player.id,
      name: `${player.first_name} ${player.last_name}`,
      pos: player.position,
      team: player.team || "FA",
      age: player.age,
      signal,
      note,
      addedAt: new Date().toISOString(),
    }]);
    setSearch("");
    setSearchResults([]);
  };

  const removeFromList = (id) => setWatchList(prev => prev.filter(w => w.id !== id));
  const updateSignal = (id, signal) => setWatchList(prev => prev.map(w => w.id === id ? { ...w, signal } : w));
  const updateNote = (id, note) => setWatchList(prev => prev.map(w => w.id === id ? { ...w, note } : w));

  const myPlayerIds = new Set(myRoster?.players || []);
  const filtered = filter === "all" ? watchList
    : filter === "buy" ? watchList.filter(w => w.signal === "BUY")
    : filter === "sell" ? watchList.filter(w => w.signal === "SELL")
    : watchList.filter(w => w.signal === "WATCH");

  // Build FC player list for the full player table
  const [wlPosFilter, setWlPosFilter] = useState("ALL");
  const [wlSearch, setWlSearch] = useState("");
  const [wlView, setWlView] = useState("players"); // "players" | "watchlist"

  const fcPlayerList = Object.entries(fcPlayers || {}).map(([sleeperId, fc]) => ({
    sleeperId,
    ...fc,
    onRoster: myPlayerIds.has(sleeperId),
    onWatchList: !!watchList.find(w => w.id === sleeperId),
  })).sort((a, b) => a.fcOverallRank - b.fcOverallRank);

  const filteredFcPlayers = fcPlayerList
    .filter(p => wlPosFilter === "ALL" || p.fcPos === wlPosFilter)
    .filter(p => !wlSearch || p.fcName.toLowerCase().includes(wlSearch.toLowerCase()));

  const addFromFcTable = (p, signal) => {
    if (watchList.find(w => w.id === p.sleeperId)) return;
    setWatchList(prev => [...prev, {
      id: p.sleeperId,
      name: p.fcName,
      pos: p.fcPos,
      team: p.fcTeam || "FA",
      age: p.fcAge,
      fcValue: p.fcValue,
      fcOverallRank: p.fcOverallRank,
      fcPosRank: p.fcPosRank,
      signal,
      note: "",
      addedAt: new Date().toISOString(),
    }]);
  };

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
      {/* View toggle */}
      <div style={{ display: "flex", gap: 0, borderBottom: `1px solid ${C.border}` }}>
        {[{ id: "players", label: `All Players (${fcPlayerList.length})` }, { id: "watchlist", label: `My Watch List (${watchList.length})` }].map(v => (
          <button key={v.id} onClick={() => setWlView(v.id)} style={{
            background: "transparent", border: "none",
            borderBottom: `2px solid ${wlView === v.id ? C.accent : "transparent"}`,
            color: wlView === v.id ? C.accent : C.muted,
            fontFamily: "'DM Mono', monospace", fontSize: 11, fontWeight: 700,
            letterSpacing: "0.1em", textTransform: "uppercase",
            padding: "10px 20px", cursor: "pointer",
          }}>{v.label}</button>
        ))}
      </div>

      {wlView === "players" && (
        <>
          {/* Controls */}
          <div style={{ display: "flex", gap: 8, alignItems: "center", flexWrap: "wrap" }}>
            <input value={wlSearch} onChange={e => setWlSearch(e.target.value)} placeholder="Search player…"
              style={{ padding: "8px 12px", background: C.surface, border: `1px solid ${C.border}`, borderRadius: 4, color: C.text, fontSize: 12, fontFamily: "'DM Mono', monospace", outline: "none", width: 180 }} />
            <div style={{ display: "flex", gap: 4 }}>
              {["ALL", "QB", "RB", "WR", "TE"].map(pos => (
                <button key={pos} onClick={() => setWlPosFilter(pos)} style={{
                  background: wlPosFilter === pos ? C.accentLight : "transparent",
                  color: wlPosFilter === pos ? C.accent : C.muted,
                  border: `1px solid ${wlPosFilter === pos ? C.accent : C.border}`,
                  borderRadius: 3, fontSize: 10, fontWeight: 700, padding: "5px 9px",
                  cursor: "pointer", fontFamily: "'DM Mono', monospace",
                }}>{pos}</button>
              ))}
            </div>
            <div style={{ fontSize: 10, color: C.muted, fontFamily: "'DM Mono', monospace", marginLeft: "auto" }}>
              {filteredFcPlayers.length} players · Click BUY / WATCH / SELL to add to your watch list
            </div>
          </div>

          {!fcPlayers ? <Spinner label="Loading FantasyCalc player values…" /> : (
            <div style={{ ...card, padding: 0, overflow: "hidden" }}>
              <table style={{ width: "100%", borderCollapse: "collapse", fontFamily: "'DM Mono', monospace", fontSize: 12 }}>
                <thead>
                  <tr style={{ borderBottom: `1px solid ${C.border}`, background: C.surfaceHigh }}>
                    {["FC #", "Pos", "Player", "Team", "Age", "Yrs Exp", "FC Pos Rank", "FC Value", ""].map(h => (
                      <th key={h} style={{ padding: "9px 14px", color: C.muted, fontWeight: 600, fontSize: 10, textTransform: "uppercase", letterSpacing: "0.08em", textAlign: h === "Player" || h === "Team" ? "left" : "right", whiteSpace: "nowrap" }}>{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {filteredFcPlayers.map((p, i) => (
                    <tr key={p.sleeperId}
                      style={{ borderBottom: `1px solid ${C.border}`, background: p.onRoster ? `${C.accent}08` : "transparent", transition: "background 0.1s" }}
                      onMouseEnter={e => e.currentTarget.style.background = C.surfaceHigh}
                      onMouseLeave={e => e.currentTarget.style.background = p.onRoster ? `${C.accent}08` : "transparent"}>
                      <td style={{ padding: "9px 14px", color: C.muted, textAlign: "right" }}>{p.fcOverallRank}</td>
                      <td style={{ padding: "9px 14px" }}><span style={{ ...badge(posColor(p.fcPos)) }}>{p.fcPos}</span></td>
                      <td style={{ padding: "9px 14px", color: C.text, fontWeight: 600, whiteSpace: "nowrap" }}>
                        {p.fcName}
                        {p.onRoster && <span style={{ ...badge(C.accent), marginLeft: 8, fontSize: 9 }}>ROSTER</span>}
                      </td>
                      <td style={{ padding: "9px 14px", color: C.muted }}>{p.fcTeam || "FA"}</td>
                      <td style={{ padding: "9px 14px", color: C.mutedLight, textAlign: "right" }}>{p.fcAge || "—"}</td>
                      <td style={{ padding: "9px 14px", color: p.fcYoe === 0 ? C.green : C.mutedLight, textAlign: "right" }}>
                        {p.fcYoe === 0 ? "Rookie" : p.fcYoe != null ? `Yr ${p.fcYoe + 1}` : "—"}
                      </td>
                      <td style={{ padding: "9px 14px", color: posColor(p.fcPos), textAlign: "right", fontWeight: 600 }}>{p.fcPos}{p.fcPosRank}</td>
                      <td style={{ padding: "9px 14px", color: C.accent, fontWeight: 700, textAlign: "right" }}>{p.fcValue?.toLocaleString()}</td>
                      <td style={{ padding: "9px 14px", textAlign: "right" }}>
                        {p.onWatchList ? (
                          <span style={{ fontSize: 10, color: C.muted, fontFamily: "'DM Mono', monospace" }}>Added</span>
                        ) : (
                          <div style={{ display: "flex", gap: 4, justifyContent: "flex-end" }}>
                            {["BUY", "WATCH", "SELL"].map(sig => (
                              <button key={sig} onClick={() => addFromFcTable(p, sig)} style={{
                                background: "transparent",
                                color: sig === "BUY" ? C.green : sig === "SELL" ? C.red : C.accent,
                                border: `1px solid ${sig === "BUY" ? C.green : sig === "SELL" ? C.red : C.accent}44`,
                                borderRadius: 3, fontSize: 9, fontWeight: 700, padding: "3px 7px",
                                cursor: "pointer", fontFamily: "'DM Mono', monospace",
                              }}>{sig}</button>
                            ))}
                          </div>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </>
      )}

      {wlView === "watchlist" && (
        <>

      {/* Filter pills */}
      <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
        {["all", "buy", "watch", "sell"].map(f => (
          <button key={f} onClick={() => setFilter(f)} style={{
            background: filter === f ? (f === "buy" ? C.green : f === "sell" ? C.red : f === "watch" ? C.accent : C.accent) + "22" : "transparent",
            color: filter === f ? (f === "buy" ? C.green : f === "sell" ? C.red : C.accent) : C.muted,
            border: `1px solid ${filter === f ? (f === "buy" ? C.green : f === "sell" ? C.red : C.accent) : C.border}44`,
            borderRadius: 3, fontSize: 10, fontWeight: 700, padding: "5px 12px",
            cursor: "pointer", fontFamily: "'DM Mono', monospace", letterSpacing: "0.08em", textTransform: "uppercase",
          }}>{f === "all" ? `All (${watchList.length})` : `${f.toUpperCase()} (${watchList.filter(w => w.signal === f.toUpperCase()).length})`}</button>
        ))}
        <div style={{ marginLeft: "auto", fontSize: 11, color: C.muted, fontFamily: "'DM Mono', monospace" }}>
          Your personal trade board — tag and annotate players
        </div>
      </div>

      {filtered.length === 0 ? (
        <div style={{ ...statBox, color: C.muted, fontSize: 13, fontFamily: "'DM Mono', monospace", textAlign: "center", padding: 40 }}>
          No players in this view. Search above to add players to your watch list.
        </div>
      ) : (
        <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
          {filtered.map(w => (
            <WatchListCard key={w.id} item={w} onRemove={removeFromList} onSignalChange={updateSignal} onNoteChange={updateNote} myPlayerIds={myPlayerIds} />
          ))}
        </div>
      )}
        </>
      )}
    </div>
  );
}

function WatchListCard({ item, onRemove, onSignalChange, onNoteChange, myPlayerIds }) {
  const [editing, setEditing] = useState(false);
  const [note, setNote] = useState(item.note || "");
  const sigColor = item.signal === "BUY" ? C.green : item.signal === "SELL" ? C.red : C.accent;

  return (
    <div style={{ ...card, borderLeft: `3px solid ${sigColor}` }}>
      <div style={{ display: "flex", alignItems: "flex-start", justifyContent: "space-between", gap: 16 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
          <span style={{ ...badge(posColor(item.pos)) }}>{item.pos}</span>
          <div>
            <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 18, fontWeight: 700, color: C.text, display: "flex", alignItems: "center", gap: 8 }}>
              {item.name}
              {myPlayerIds.has(item.id) && <span style={{ ...badge(C.green), fontSize: 9 }}>ON YOUR ROSTER</span>}
            </div>
            <div style={{ fontSize: 11, fontFamily: "'DM Mono', monospace", color: C.muted, marginTop: 2 }}>
              {item.team} · Age {item.age}
            </div>
          </div>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
          {["BUY", "WATCH", "SELL"].map(sig => (
            <button key={sig} onClick={() => onSignalChange(item.id, sig)} style={{
              background: item.signal === sig ? `${sig === "BUY" ? C.green : sig === "SELL" ? C.red : C.accent}22` : "transparent",
              color: item.signal === sig ? (sig === "BUY" ? C.green : sig === "SELL" ? C.red : C.accent) : C.muted,
              border: `1px solid ${item.signal === sig ? (sig === "BUY" ? C.green : sig === "SELL" ? C.red : C.accent) + "44" : C.border}`,
              borderRadius: 3, fontSize: 10, fontWeight: 700, padding: "4px 10px",
              cursor: "pointer", fontFamily: "'DM Mono', monospace",
            }}>{sig}</button>
          ))}
          <button onClick={() => onRemove(item.id)} style={{ background: "transparent", border: "none", color: C.muted, fontSize: 16, cursor: "pointer", padding: "0 4px" }}>×</button>
        </div>
      </div>
      {editing ? (
        <div style={{ marginTop: 12 }}>
          <textarea
            value={note}
            onChange={e => setNote(e.target.value)}
            placeholder="Notes, reasoning, trade targets…"
            style={{ width: "100%", background: C.surfaceHigh, border: `1px solid ${C.border}`, borderRadius: 4, color: C.text, fontSize: 12, fontFamily: "'DM Mono', monospace", padding: "8px 12px", resize: "vertical", minHeight: 60, boxSizing: "border-box", outline: "none" }}
          />
          <div style={{ display: "flex", gap: 8, marginTop: 6 }}>
            <button onClick={() => { onNoteChange(item.id, note); setEditing(false); }} style={{ background: C.accent, color: C.bg, border: "none", borderRadius: 3, fontSize: 11, fontWeight: 700, padding: "5px 14px", cursor: "pointer", fontFamily: "'DM Mono', monospace" }}>Save</button>
            <button onClick={() => { setNote(item.note || ""); setEditing(false); }} style={{ background: "transparent", border: `1px solid ${C.border}`, color: C.muted, borderRadius: 3, fontSize: 11, padding: "5px 14px", cursor: "pointer", fontFamily: "'DM Mono', monospace" }}>Cancel</button>
          </div>
        </div>
      ) : (
        <div style={{ marginTop: 10, display: "flex", alignItems: "flex-start", justifyContent: "space-between", gap: 12 }}>
          <div style={{ fontSize: 12, fontFamily: "'DM Mono', monospace", color: item.note ? C.mutedLight : C.muted, fontStyle: item.note ? "normal" : "italic" }}>
            {item.note || "No notes yet — click to add your analysis"}
          </div>
          <button onClick={() => setEditing(true)} style={{ background: "transparent", border: `1px solid ${C.border}`, color: C.muted, borderRadius: 3, fontSize: 10, padding: "4px 10px", cursor: "pointer", fontFamily: "'DM Mono', monospace", whiteSpace: "nowrap" }}>Edit Note</button>
        </div>
      )}
    </div>
  );
}

// ── ROOKIE DRAFT TAB ──────────────────────────────────────────────────────────
const DRAFT_YEAR = "2026";
const ROUND_LABELS = { 1: "1st", 2: "2nd", 3: "3rd", 4: "4th", 5: "5th" };

// Dynasty age score: rewards youth + positional longevity
function dynastyAgeScore(age, pos) {
  if (!age) return null;
  const posMulti = { WR: 1.0, QB: 0.9, TE: 0.85, RB: 0.7 };
  const multi = posMulti[pos] || 0.8;
  const raw = Math.max(0, (32 - parseFloat(age)) * multi);
  return Math.min(100, Math.round((raw / 20) * 100));
}

function DraftCapitalPanel({ myRoster, rosters, users }) {
  const [tradedPicks, setTradedPicks] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    async function load() {
      try {
        const picks = await sleeperFetch(`/league/${CURRENT_LEAGUE_ID}/traded_picks`, true);
        setTradedPicks(picks || []);
      } catch { setTradedPicks([]); }
      setLoading(false);
    }
    load();
  }, []);

  if (!myRoster) return null;
  const myRosterId = myRoster.roster_id;
  const totalRounds = 5;
  const leagueSize = rosters.length || 12;
  const futureYears = [DRAFT_YEAR, String(parseInt(DRAFT_YEAR) + 1)];

  // Resolve slot using hardcoded DRAFT_2026_ORDER constant.
  // 2027 and beyond: order not set yet, shows XX.
  const getCapitalSlot = (rosterId, season) => {
    if (season !== DRAFT_YEAR) return null;
    const r = rosters.find(r => r.roster_id === rosterId);
    if (!r) return null;
    const u = users.find(u => String(u.user_id) === String(r.owner_id));
    if (!u) return null;
    return getDraftSlot(u.user_id);
  };

  const ordinal = (n) => ["1st","2nd","3rd","4th","5th"][n-1] || `${n}th`;
  const capitalLabel = (pk) => {
    const slot = getCapitalSlot(pk.isOwn ? myRosterId : pk.roster_id, pk.season);
    // 2026: exact slot known → show "1.02". Future years: show "1st", "2nd" etc.
    if (slot) return `${pk.round}.${String(slot).padStart(2, "0")}`;
    return ordinal(pk.round);
  };

  // Build full set of picks I originally own (every round, every future year)
  const ownPicks = [];
  for (const year of futureYears) {
    for (let round = 1; round <= totalRounds; round++) {
      ownPicks.push({ season: year, round, roster_id: myRosterId, owner_id: myRosterId, isOwn: true });
    }
  }

  // Apply trades: remove sent picks, add received picks
  const tradedAway = tradedPicks.filter(p =>
    futureYears.includes(p.season) && p.roster_id === myRosterId && p.owner_id !== myRosterId
  );
  const received = tradedPicks.filter(p =>
    futureYears.includes(p.season) && p.owner_id === myRosterId && p.roster_id !== myRosterId
  );

  const sentKeys = new Set(tradedAway.map(p => `${p.season}-${p.round}-${p.roster_id}`));
  const myCurrentPicks = [
    ...ownPicks.filter(p => !sentKeys.has(`${p.season}-${p.round}-${p.roster_id}`)),
    ...received.map(p => ({ ...p, isOwn: false })),
  ].sort((a, b) => a.season.localeCompare(b.season) || a.round - b.round);

  const getOwnerName = (rosterId) => {
    const r = rosters.find(r => r.roster_id === rosterId);
    if (!r) return "Unknown";
    const u = users.find(u => String(u.user_id) === String(r.owner_id));
    return u?.metadata?.team_name || u?.display_name || "Unknown";
  };

  return (
    <div style={{ ...card, background: C.surfaceHigh, borderColor: C.accentDim }}>
      <SectionHeader label="My Draft Capital" />

      {loading ? (
        <div style={{ fontSize: 11, color: C.muted, fontFamily: "'DM Mono', monospace" }}>Loading picks…</div>
      ) : (
        <div style={{ display: "flex", gap: 24, flexWrap: "wrap" }}>
          {futureYears.map(year => {
            const yearPicks = myCurrentPicks.filter(p => p.season === year);
            return (
              <div key={year} style={{ flex: 1, minWidth: 180 }}>
                <div style={{ fontSize: 10, fontFamily: "'DM Mono', monospace", color: C.accent, fontWeight: 700, letterSpacing: "0.12em", textTransform: "uppercase", marginBottom: 10 }}>{year} Draft</div>
                {yearPicks.length === 0 ? (
                  <div style={{ fontSize: 11, color: C.muted, fontFamily: "'DM Mono', monospace", fontStyle: "italic" }}>No picks</div>
                ) : (
                  <div style={{ display: "flex", flexDirection: "column", gap: 5 }}>
                    {yearPicks.map((p, i) => (
                      <div key={i} style={{ display: "flex", alignItems: "center", gap: 8 }}>
                        <div style={{ ...badge(p.round === 1 ? C.accent : p.round === 2 ? C.blue : C.muted) }}>
                          {capitalLabel(p)}
                        </div>
                        <div style={{ fontSize: 10, fontFamily: "'DM Mono', monospace", color: p.isOwn ? C.muted : C.mutedLight }}>
                          {p.isOwn ? "own pick" : `via ${getOwnerName(p.roster_id)}`}
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            );
          })}
          <div style={{ flex: 1, minWidth: 180 }}>
            <div style={{ fontSize: 10, fontFamily: "'DM Mono', monospace", color: C.muted, fontWeight: 700, letterSpacing: "0.12em", textTransform: "uppercase", marginBottom: 10 }}>Traded Away</div>
            {tradedAway.filter(p => futureYears.includes(p.season)).length === 0 ? (
              <div style={{ fontSize: 11, color: C.muted, fontFamily: "'DM Mono', monospace", fontStyle: "italic" }}>None</div>
            ) : (
              <div style={{ display: "flex", flexDirection: "column", gap: 5 }}>
                {tradedAway.filter(p => futureYears.includes(p.season)).map((p, i) => (
                  <div key={i} style={{ display: "flex", alignItems: "center", gap: 8 }}>
                    <div style={{ ...badge(C.red) }}>{p.season} {capitalLabel(p)}</div>
                    <div style={{ fontSize: 10, fontFamily: "'DM Mono', monospace", color: C.muted }}>
                      to {getOwnerName(p.owner_id)}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}

function RookieDraftTab({ allPlayers, myRoster, rosters, users }) {
  const [consensusBoard, setConsensusBoard] = useState([]);
  const [consensusLoading, setConsensusLoading] = useState(true);
  const [consensusError, setConsensusError] = useState(false);
  const [tradedPicks, setTradedPicks] = useState([]);
  const [posFilter, setPosFilter] = useState("ALL");
  const [sortBy, setSortBy] = useState("fc");
  const [search, setSearch] = useState("");
  const [activeView, setActiveView] = useState("consensus"); // "consensus" | "bgmboard"
  const [pickFilter, setPickFilter] = useState(null); // selected pick slot label e.g. "1st"

  // Auto-load FantasyCalc consensus rookies on mount
  useEffect(() => {
    async function loadConsensus() {
      setConsensusLoading(true);
      setConsensusError(false);
      try {
        const res = await fetch(
          "https://api.fantasycalc.com/values/current?isDynasty=true&numQbs=1&numTeams=12&ppr=0.5&rookiesOnly=1"
        );
        if (!res.ok) throw new Error();
        const data = await res.json();
        const relevant = ["QB", "RB", "WR", "TE"];
        const enriched = data
          .filter(d => {
            if (!relevant.includes(d.player?.position)) return false;
            // Hard rookie gate: FantasyCalc's maybeYoe (years of experience) must be 0
            // This is the most reliable field — it's 0 only for true rookies
            if (d.player?.maybeYoe !== 0 && d.player?.maybeYoe !== null && d.player?.maybeYoe !== undefined) return false;
            // Secondary gate: if player is in Sleeper, years_exp must be 0
            const sp = allPlayers && d.player?.sleeperId ? allPlayers[d.player.sleeperId] : null;
            if (sp && sp.years_exp !== 0 && sp.years_exp !== null) return false;
            return true;
          })
          .map(d => {
            const sp = allPlayers && d.player?.sleeperId ? allPlayers[d.player.sleeperId] : null;
            return {
              sleeperId: d.player?.sleeperId || null,
              name: d.player?.name || "Unknown",
              pos: d.player?.position || "?",
              team: sp?.team || d.player?.maybeTeam || "UND",
              college: sp?.college || d.player?.maybeCollege || "—",
              age: d.player?.maybeAge ? parseFloat(d.player.maybeAge).toFixed(1) : (sp?.age || "—"),
              fcValue: d.value,
              fcRank: d.overallRank,
              posRank: d.positionRank,
              trend: d.trend30Day || 0,
              dynastyScore: dynastyAgeScore(d.player?.maybeAge, d.player?.position),
            };
          });
        // Compute rookie-specific positional rank (RB1 among rookies, not overall RB3)
        const posCounts = {};
        const withRookiePosRank = enriched
          .sort((a, b) => a.fcRank - b.fcRank)
          .map(p => {
            posCounts[p.pos] = (posCounts[p.pos] || 0) + 1;
            return { ...p, rookiePosRank: posCounts[p.pos] };
          })
          .sort((a, b) => a.fcRank - b.fcRank);
        setConsensusBoard(withRookiePosRank);
      } catch {
        setConsensusError(true);
      }
      setConsensusLoading(false);
    }
    if (allPlayers) loadConsensus();
  }, [allPlayers]);

  // Load traded picks for pick filter
  useEffect(() => {
    sleeperFetch(`/league/${CURRENT_LEAGUE_ID}/traded_picks`, true)
      .then(setTradedPicks)
      .catch(() => setTradedPicks([]));
  }, []);

  // ── Compute BGM Board analytically ──────────────────────────────────────────
  // Formula: BGM Score = KTC normalized (40%) + Dynasty Score (35%) + Trend momentum (15%) + position bonus (10%)
  // All factors are normalized 0-100 then weighted
  const bgmBoard = (() => {
    if (!consensusBoard.length) return [];
    const maxFc = Math.max(...consensusBoard.map(p => p.fcValue || 0));
    const posBonusMap = { WR: 10, TE: 7, QB: 5, RB: 2 };

    const scored = consensusBoard
      .map(p => {
        // BGM Score = FantasyCalc value (55%) + Dynasty age-position score (35%) + Position bonus (10%)
        const fcNorm = maxFc > 0 ? ((p.fcValue || 0) / maxFc) * 100 : 0;
        const ageScore = p.dynastyScore || 50;
        const posBonus = posBonusMap[p.pos] || 5;
        const bgmScore = Math.round(fcNorm * 0.55 + ageScore * 0.35 + posBonus * 0.10);
        return { ...p, bgmScore };
      })
      .sort((a, b) => b.bgmScore - a.bgmScore)
      .map((p, i) => ({ ...p, bgmRank: i + 1 }));

    // Compute BGM positional rank (RB1, WR1, etc.) based on BGM board order
    const bgmPosCounts = {};
    return scored.map(p => {
      bgmPosCounts[p.pos] = (bgmPosCounts[p.pos] || 0) + 1;
      return { ...p, bgmPosRank: bgmPosCounts[p.pos] };
    });
  })();

  // ── My 2026 picks for the pick filter ───────────────────────────────────────
  const myRosterId = myRoster?.roster_id;
  const leagueSize = rosters.length || 12;
  const futureYears = [DRAFT_YEAR, String(parseInt(DRAFT_YEAR) + 1)];

  // Resolve any roster_id to its 2026 draft slot using the hardcoded draft_order
  const getSlotForRoster = (rosterId) => {
    if (!rosterId) return null;
    const r = rosters.find(r => r.roster_id === rosterId);
    if (!r) return null;
    const u = users.find(u => String(u.user_id) === String(r.owner_id));
    if (!u) return null;
    return getDraftSlot(u.user_id);
  };

  // My own slot — derived once
  const myDraftSlot = getSlotForRoster(myRosterId);

  const ownPicks = [];
  if (myRosterId) {
    for (let round = 1; round <= 5; round++) {
      ownPicks.push({ season: DRAFT_YEAR, round, roster_id: myRosterId, owner_id: myRosterId, isOwn: true });
    }
  }
  const tradedAway2026 = tradedPicks.filter(p => p.season === DRAFT_YEAR && p.roster_id === myRosterId && p.owner_id !== myRosterId);
  const received2026 = tradedPicks.filter(p => p.season === DRAFT_YEAR && p.owner_id === myRosterId && p.roster_id !== myRosterId);
  const sentKeys = new Set(tradedAway2026.map(p => `${p.round}-${p.roster_id}`));
  const myCurrentPicks = [
    ...ownPicks.filter(p => !sentKeys.has(`${p.round}-${p.roster_id}`)),
    ...received2026.map(p => ({ ...p, isOwn: false })),
  ].sort((a, b) => a.round - b.round);

  // Draft type is "linear" — slot stays the same every round (no snake reversal)
  // Overall pick = (round - 1) * teams + slot
  const slotForPick = (pk) => {
    if (pk.isOwn) return myDraftSlot;
    // For received picks: look up original owner's slot
    return getSlotForRoster(pk.roster_id);
  };
  const overallPickNum = (round, slot) => {
    const s = slot ?? Math.ceil(leagueSize / 2);
    return (round - 1) * leagueSize + s;
  };
  // Pick label — e.g. "1.02" if slot known, "1.XX" if not; * = received via trade
  const pickLabel = (pk) => {
    const slot = slotForPick(pk);
    const slotStr = slot ? String(slot).padStart(2, "0") : "XX";
    const label = `${pk.round}.${slotStr}`;
    return label;
  };
  // Overall pick number for filter anchor
  const pickOverall = (pk) => {
    const slot = slotForPick(pk);
    return overallPickNum(pk.round, slot);
  };

  const tierColors = { "1": C.accent, "2": C.blue, "3": C.green, "4": C.muted };
  const posColors = ["ALL", "QB", "RB", "WR", "TE"];

  // Consensus board filters
  const filteredConsensus = consensusBoard
    .filter(p => posFilter === "ALL" || p.pos === posFilter)
    .filter(p => !search || p.name.toLowerCase().includes(search.toLowerCase()));
  // Recompute rookiePosRank based on current sort order so it always reflects
  // the displayed ordering, not a fixed KTC ordering
  const buildSortedConsensus = () => {
    const base = [...filteredConsensus].sort((a, b) => {
      if (sortBy === "fc") return a.fcRank - b.fcRank;
      if (sortBy === "dynasty") return (b.dynastyScore || 0) - (a.dynastyScore || 0);
      if (sortBy === "trend") return b.trend - a.trend;
      return a.fcRank - b.fcRank;
    });
    // Assign display positional ranks based on current sort order
    const posCounts = {};
    return base.map(p => {
      posCounts[p.pos] = (posCounts[p.pos] || 0) + 1;
      return { ...p, displayPosRank: posCounts[p.pos] };
    });
  };
  const sortedConsensus = buildSortedConsensus();

  // BGM board pick filter: ±10 BGM rookie ranks around this pick's overall slot
  const filteredBgm = bgmBoard.filter(p => {
    if (!pickFilter) return true;
    const idx = parseInt(pickFilter.replace("pick-", ""));
    const pick = myCurrentPicks[idx];
    if (!pick) return true;
    const overall = pickOverall(pick);
    return p.bgmRank >= Math.max(1, overall - 10) && p.bgmRank <= overall + 10;
  }).filter(p => posFilter === "ALL" || p.pos === posFilter);

  const inp = {
    padding: "8px 12px", background: C.surface, border: `1px solid ${C.border}`,
    borderRadius: 4, color: C.text, fontSize: 12, fontFamily: "'DM Mono', monospace",
    outline: "none",
  };

  const ScoreBadge = ({ score, max = 100 }) => (
    <div style={{ display: "inline-flex", alignItems: "center", gap: 6 }}>
      <div style={{ width: 44, height: 5, background: C.border, borderRadius: 3, overflow: "hidden" }}>
        <div style={{ width: `${(score / max) * 100}%`, height: "100%", background: score > 70 ? C.green : score > 45 ? C.accent : C.red, borderRadius: 3 }} />
      </div>
      <span style={{ fontSize: 11, color: score > 70 ? C.green : score > 45 ? C.accent : C.red, fontWeight: 600 }}>{score}</span>
    </div>
  );

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>

      {/* View tabs */}
      <div style={{ display: "flex", gap: 0, borderBottom: `1px solid ${C.border}` }}>
        {[
          { id: "consensus", label: `Consensus Board${consensusBoard.length ? ` (${consensusBoard.length})` : ""}` },
          { id: "bgmboard", label: `BGM Board${bgmBoard.length ? ` (${bgmBoard.length})` : ""}` },
        ].map(v => (
          <button key={v.id} onClick={() => setActiveView(v.id)} style={{
            background: "transparent", border: "none",
            borderBottom: `2px solid ${activeView === v.id ? C.accent : "transparent"}`,
            color: activeView === v.id ? C.accent : C.muted,
            fontFamily: "'DM Mono', monospace", fontSize: 11, fontWeight: 700,
            letterSpacing: "0.1em", textTransform: "uppercase",
            padding: "10px 20px", cursor: "pointer",
          }}>{v.label}</button>
        ))}
      </div>

      {/* Shared controls row */}
      <div style={{ display: "flex", gap: 8, alignItems: "center", flexWrap: "wrap" }}>
        {activeView === "consensus" && (
          <input value={search} onChange={e => setSearch(e.target.value)} placeholder="Search player…" style={{ ...inp, width: 160 }} />
        )}
        <div style={{ display: "flex", gap: 4 }}>
          {posColors.map(p => (
            <button key={p} onClick={() => setPosFilter(p)} style={{
              background: posFilter === p ? C.accentLight : "transparent",
              color: posFilter === p ? C.accent : C.muted,
              border: `1px solid ${posFilter === p ? C.accent : C.border}`,
              borderRadius: 3, fontSize: 10, fontWeight: 700, padding: "5px 9px",
              cursor: "pointer", fontFamily: "'DM Mono', monospace",
            }}>{p}</button>
          ))}
        </div>

        {activeView === "consensus" && (
          <div style={{ display: "flex", gap: 4, marginLeft: "auto", alignItems: "center" }}>
            <div style={{ fontSize: 10, color: C.muted, fontFamily: "'DM Mono', monospace", marginRight: 2 }}>Sort:</div>
            {[["fc", "FantasyCalc Rank"], ["dynasty", "Dynasty Score"]].map(([k, label]) => (
              <button key={k} onClick={() => setSortBy(k)} style={{
                background: sortBy === k ? C.accentLight : "transparent",
                color: sortBy === k ? C.accent : C.muted,
                border: `1px solid ${sortBy === k ? C.accent : C.border}`,
                borderRadius: 3, fontSize: 10, fontWeight: 700, padding: "5px 9px",
                cursor: "pointer", fontFamily: "'DM Mono', monospace",
              }}>{label}</button>
            ))}
          </div>
        )}

        {activeView === "bgmboard" && myCurrentPicks.length > 0 && (
          <div style={{ display: "flex", gap: 4, marginLeft: "auto", alignItems: "center", flexWrap: "wrap" }}>
            <div style={{ fontSize: 10, color: C.muted, fontFamily: "'DM Mono', monospace", marginRight: 2 }}>My {DRAFT_YEAR} picks:</div>
            <button onClick={() => setPickFilter(null)} style={{
              background: !pickFilter ? C.accentLight : "transparent",
              color: !pickFilter ? C.accent : C.muted,
              border: `1px solid ${!pickFilter ? C.accent : C.border}`,
              borderRadius: 3, fontSize: 10, fontWeight: 700, padding: "5px 9px",
              cursor: "pointer", fontFamily: "'DM Mono', monospace",
            }}>All</button>
            {[...myCurrentPicks]
              .sort((a, b) => pickOverall(a) - pickOverall(b))
              .map((pk, i) => {
                // Use position in the SORTED array as the stable filter key
                const sortedIdx = myCurrentPicks.indexOf(pk);
                const filterKey = `pick-${sortedIdx}`;
                const slot = slotForPick(pk);
                // Label: exact slot if known (no asterisk — ownership is irrelevant here)
                const label = slot
                  ? `${pk.round}.${String(slot).padStart(2, "0")}`
                  : `${pk.round}.XX`;
                const overall = pickOverall(pk);
                return (
                  <button key={i} onClick={() => setPickFilter(pickFilter === filterKey ? null : filterKey)} style={{
                    background: pickFilter === filterKey ? C.accentLight : "transparent",
                    color: pickFilter === filterKey ? C.accent : C.muted,
                    border: `1px solid ${pickFilter === filterKey ? C.accent : C.border}`,
                    borderRadius: 3, fontSize: 10, fontWeight: 700, padding: "5px 9px",
                    cursor: "pointer", fontFamily: "'DM Mono', monospace",
                    title: `Pick #${overall} overall · shows BGM ranks ${Math.max(1, overall-10)}–${overall+10}`,
                  }}>{label}</button>
                );
              })}
            {pickFilter && (() => {
              const idx = parseInt(pickFilter.replace("pick-", ""));
              const pick = myCurrentPicks[idx];
              const overall = pick ? pickOverall(pick) : null;
              return overall ? (
                <div style={{ fontSize: 10, color: C.muted, fontFamily: "'DM Mono', monospace", fontStyle: "italic" }}>
                  pick #{overall} overall · showing #{Math.max(1, overall - 10)}–#{overall + 10}
                </div>
              ) : null;
            })()}
          </div>
        )}
      </div>

      {/* ── CONSENSUS BOARD ── */}
      {activeView === "consensus" && (
        <>
          <div style={{ display: "flex", gap: 16, flexWrap: "wrap" }}>
            <div style={{ fontSize: 10, fontFamily: "'DM Mono', monospace", color: C.muted }}>
              <span style={{ color: C.text, fontWeight: 600 }}>FantasyCalc Value</span> — dynasty trade value from FantasyCalc (max 9999)
            </div>
            <div style={{ fontSize: 10, fontFamily: "'DM Mono', monospace", color: C.muted }}>
              <span style={{ color: C.text, fontWeight: 600 }}>Rookie Pos Rank</span> — positional rank among this rookie class only
            </div>

          </div>

          {consensusLoading ? <Spinner label="Loading FantasyCalc consensus board…" />
          : consensusError ? (
            <div style={{ ...card, color: C.muted, fontSize: 12, fontFamily: "'DM Mono', monospace" }}>
              Could not reach FantasyCalc. Check connection and refresh.
            </div>
          ) : (
            <div style={{ ...card, padding: 0, overflow: "hidden" }}>
              <table style={{ width: "100%", borderCollapse: "collapse", fontFamily: "'DM Mono', monospace", fontSize: 12 }}>
                <thead>
                  <tr style={{ borderBottom: `1px solid ${C.border}`, background: C.surfaceHigh }}>
                    {["FC #", "Pos", "Player", "Team", "Age", "College", "FC Value", "Rookie Pos Rank"].map(h => (
                      <th key={h} style={{ padding: "9px 14px", color: C.muted, fontWeight: 600, fontSize: 10, textTransform: "uppercase", letterSpacing: "0.08em", textAlign: h === "Player" || h === "Team" || h === "College" ? "left" : "right", whiteSpace: "nowrap" }}>{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {sortedConsensus.map((p, i) => (
                    <tr key={p.sleeperId || i}
                      style={{ borderBottom: `1px solid ${C.border}`, transition: "background 0.1s" }}
                      onMouseEnter={e => e.currentTarget.style.background = C.surfaceHigh}
                      onMouseLeave={e => e.currentTarget.style.background = "transparent"}>
                      <td style={{ padding: "9px 14px", color: C.muted, textAlign: "right", fontWeight: 600 }}>{p.fcRank}</td>
                      <td style={{ padding: "9px 14px" }}><span style={{ ...badge(posColor(p.pos)) }}>{p.pos}</span></td>
                      <td style={{ padding: "9px 14px", color: C.text, fontWeight: 600, whiteSpace: "nowrap" }}>{p.name}</td>
                      <td style={{ padding: "9px 14px", color: C.muted }}>{p.team}</td>
                      <td style={{ padding: "9px 14px", color: C.mutedLight, textAlign: "right" }}>{p.age}</td>
                      <td style={{ padding: "9px 14px", color: C.mutedLight, whiteSpace: "nowrap" }}>{p.college}</td>
                      <td style={{ padding: "9px 14px", color: C.accent, fontWeight: 700, textAlign: "right" }}>{p.fcValue?.toLocaleString()}</td>
                      <td style={{ padding: "9px 14px", color: C.mutedLight, textAlign: "right" }}>{p.pos}{p.displayPosRank}</td>

                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </>
      )}

      {/* ── BGM BOARD ── */}
      {activeView === "bgmboard" && (
        <>
          <div style={{ ...card, background: C.surfaceHigh, borderColor: C.accentDim, padding: "12px 18px" }}>
            <div style={{ fontSize: 10, fontFamily: "'DM Mono', monospace", color: C.accent, fontWeight: 700, letterSpacing: "0.1em", textTransform: "uppercase", marginBottom: 6 }}>BGM Scoring Methodology</div>
            <div style={{ display: "flex", gap: 20, flexWrap: "wrap" }}>
              {[["FantasyCalc Value", "55%", "Normalized dynasty trade value from FantasyCalc rookie board"], ["Dynasty Score", "35%", "(32 − age) × positional longevity multiplier, normalized 0–100"], ["Position Bonus", "10%", "WR > TE > QB > RB — rewards positions with longer dynasty shelf life"]].map(([label, pct, desc]) => (
                <div key={label} style={{ fontSize: 10, fontFamily: "'DM Mono', monospace" }}>
                  <span style={{ color: C.text, fontWeight: 700 }}>{label}</span>
                  <span style={{ color: C.accent, fontWeight: 700 }}> {pct}</span>
                  <span style={{ color: C.muted }}> — {desc}</span>
                </div>
              ))}
            </div>
          </div>

          {consensusLoading ? <Spinner label="Building BGM board…" /> : (
            <div style={{ ...card, padding: 0, overflow: "hidden" }}>
              <table style={{ width: "100%", borderCollapse: "collapse", fontFamily: "'DM Mono', monospace", fontSize: 12 }}>
                <thead>
                  <tr style={{ borderBottom: `1px solid ${C.border}`, background: C.surfaceHigh }}>
                    {["BGM #", "FC #", "Pos", "Player", "Team", "Age", "BGM Score", "FC Value", "Dynasty Score"].map(h => (
                      <th key={h} style={{ padding: "9px 14px", color: C.muted, fontWeight: 600, fontSize: 10, textTransform: "uppercase", letterSpacing: "0.08em", textAlign: h === "Player" || h === "Team" ? "left" : "right", whiteSpace: "nowrap" }}>{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {filteredBgm.map((p, i) => {
                    const rankDelta = p.fcRank - p.bgmRank;
                    return (
                      <tr key={p.sleeperId || i}
                        style={{ borderBottom: `1px solid ${C.border}`, transition: "background 0.1s" }}
                        onMouseEnter={e => e.currentTarget.style.background = C.surfaceHigh}
                        onMouseLeave={e => e.currentTarget.style.background = "transparent"}>
                        <td style={{ padding: "9px 14px", textAlign: "right" }}>
                          <span style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 16, fontWeight: 800, color: C.accent }}>#{p.bgmRank}</span>
                        </td>
                        <td style={{ padding: "9px 14px", textAlign: "right" }}>
                          <div style={{ display: "flex", alignItems: "center", gap: 4, justifyContent: "flex-end" }}>
                            <span style={{ color: C.muted }}>#{p.fcRank}</span>
                            {rankDelta !== 0 && (
                              <span style={{ fontSize: 9, color: rankDelta > 3 ? C.green : rankDelta < -3 ? C.red : C.muted, fontWeight: 700 }}>
                                {rankDelta > 0 ? `↑${rankDelta}` : `↓${Math.abs(rankDelta)}`}
                              </span>
                            )}
                          </div>
                        </td>
                        <td style={{ padding: "9px 14px" }}><span style={{ ...badge(posColor(p.pos)) }}>{p.pos}</span></td>
                        <td style={{ padding: "9px 14px", color: C.text, fontWeight: 600, whiteSpace: "nowrap" }}>{p.name}</td>
                        <td style={{ padding: "9px 14px", color: C.muted }}>{p.team}</td>
                        <td style={{ padding: "9px 14px", color: C.mutedLight, textAlign: "right" }}>{p.age}</td>
                        <td style={{ padding: "9px 14px", textAlign: "right" }}>
                          <ScoreBadge score={p.bgmScore} />
                        </td>
                        <td style={{ padding: "9px 14px", color: C.accent, fontWeight: 700, textAlign: "right" }}>{p.fcValue?.toLocaleString()}</td>
                        <td style={{ padding: "9px 14px", textAlign: "right" }}>
                          {p.dynastyScore != null ? <ScoreBadge score={p.dynastyScore} /> : "—"}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}
        </>
      )}
    </div>
  );
}

function MyBoardCard({ rookie, onUpdate, onRemove, onMove, tierColors }) {
  const [editNote, setEditNote] = useState(false);
  const [note, setNote] = useState(rookie.note || "");

  const deltaRank = rookie.fcRank && rookie.myRank ? rookie.fcRank - rookie.myRank : null;
  // positive delta = you're higher than consensus; negative = fading them

  return (
    <div style={{ ...card, borderLeft: `3px solid ${tierColors[rookie.tier] || C.muted}`, padding: "14px 18px" }}>
      <div style={{ display: "flex", alignItems: "flex-start", gap: 14, flexWrap: "wrap" }}>
        {/* Rank controls */}
        <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 1, minWidth: 32 }}>
          <button onClick={() => onMove(rookie.sleeperId, -1)} style={{ background: "transparent", border: "none", color: C.muted, cursor: "pointer", fontSize: 12 }}>▲</button>
          <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 22, fontWeight: 800, color: C.accent, lineHeight: 1 }}>#{rookie.myRank}</div>
          <button onClick={() => onMove(rookie.sleeperId, 1)} style={{ background: "transparent", border: "none", color: C.muted, cursor: "pointer", fontSize: 12 }}>▼</button>
        </div>
        {/* Player info */}
        <div style={{ flex: 1, minWidth: 200 }}>
          <div style={{ display: "flex", alignItems: "center", gap: 8, flexWrap: "wrap", marginBottom: 4 }}>
            <span style={{ ...badge(posColor(rookie.pos)) }}>{rookie.pos}</span>
            <span style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 19, fontWeight: 700, color: C.text }}>{rookie.name}</span>
            <span style={{ fontSize: 11, fontFamily: "'DM Mono', monospace", color: C.muted }}>{rookie.team} · Age {rookie.age}</span>
            {deltaRank !== null && (
              <span style={{ ...badge(deltaRank > 3 ? C.green : deltaRank < -3 ? C.red : C.muted), fontSize: 9 }}>
                {deltaRank > 0 ? `↑ ${deltaRank} vs KTC` : deltaRank < 0 ? `↓ ${Math.abs(deltaRank)} vs KTC` : "= KTC"}
              </span>
            )}
          </div>
          {editNote ? (
            <div>
              <textarea value={note} onChange={e => setNote(e.target.value)} placeholder="Scouting notes, NFL landing spot, comps, concerns…"
                style={{ width: "100%", background: C.surfaceHigh, border: `1px solid ${C.border}`, borderRadius: 4, color: C.text, fontSize: 12, fontFamily: "'DM Mono', monospace", padding: "7px 10px", resize: "vertical", minHeight: 50, boxSizing: "border-box", outline: "none" }}
              />
              <div style={{ display: "flex", gap: 6, marginTop: 4 }}>
                <button onClick={() => { onUpdate(rookie.sleeperId, "note", note); setEditNote(false); }} style={{ background: C.accent, color: C.white, border: "none", borderRadius: 3, fontSize: 10, fontWeight: 700, padding: "4px 12px", cursor: "pointer", fontFamily: "'DM Mono', monospace" }}>Save</button>
                <button onClick={() => { setNote(rookie.note || ""); setEditNote(false); }} style={{ background: "transparent", border: `1px solid ${C.border}`, color: C.muted, borderRadius: 3, fontSize: 10, padding: "4px 12px", cursor: "pointer", fontFamily: "'DM Mono', monospace" }}>Cancel</button>
              </div>
            </div>
          ) : (
            <div onClick={() => setEditNote(true)} style={{ fontSize: 11, fontFamily: "'DM Mono', monospace", color: rookie.note ? C.text : C.muted, fontStyle: rookie.note ? "normal" : "italic", cursor: "pointer" }}>
              {rookie.note || "Click to add scouting notes…"}
            </div>
          )}
        </div>
        {/* Controls */}
        <div style={{ display: "flex", alignItems: "center", gap: 10, flexWrap: "wrap" }}>
          <div>
            <div style={{ fontSize: 9, fontFamily: "'DM Mono', monospace", color: C.muted, textTransform: "uppercase", letterSpacing: "0.08em", marginBottom: 3 }}>Tier</div>
            <select value={rookie.tier} onChange={e => onUpdate(rookie.sleeperId, "tier", e.target.value)}
              style={{ background: C.surfaceHigh, border: `1px solid ${C.border}`, borderRadius: 3, color: tierColors[rookie.tier], fontSize: 12, fontFamily: "'DM Mono', monospace", padding: "4px 8px", outline: "none", cursor: "pointer" }}>
              {["1", "2", "3", "4"].map(t => <option key={t} value={t} style={{ color: C.text }}>T{t}</option>)}
            </select>
          </div>
          <div>
            <div style={{ fontSize: 9, fontFamily: "'DM Mono', monospace", color: C.muted, textTransform: "uppercase", letterSpacing: "0.08em", marginBottom: 3 }}>Target Pick</div>
            <input value={rookie.targetPick} onChange={e => onUpdate(rookie.sleeperId, "targetPick", e.target.value)}
              placeholder="1.04…"
              style={{ width: 64, background: C.surfaceHigh, border: `1px solid ${C.border}`, borderRadius: 3, color: C.text, fontSize: 12, fontFamily: "'DM Mono', monospace", padding: "4px 8px", outline: "none" }}
            />
          </div>
          <div style={{ textAlign: "right" }}>
            <div style={{ fontSize: 9, fontFamily: "'DM Mono', monospace", color: C.muted, textTransform: "uppercase", letterSpacing: "0.08em", marginBottom: 3 }}>KTC Rank</div>
            <div style={{ fontSize: 13, fontFamily: "'DM Mono', monospace", color: C.muted }}>#{rookie.fcRank}</div>
          </div>
          <button onClick={() => onRemove(rookie.sleeperId)} style={{ background: "transparent", border: "none", color: C.muted, fontSize: 16, cursor: "pointer", marginTop: 14 }}>×</button>
        </div>
      </div>
    </div>
  );
}

// ── LEAGUE HISTORY TAB ────────────────────────────────────────────────────────
function LeagueHistoryTab({ rosters, users }) {
  const [view, setView] = useState("standings");
  const [selectedTeam, setSelectedTeam] = useState(null);
  const [allSeasonData, setAllSeasonData] = useState({});
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    async function fetchAllSeasons() {
      setLoading(true);
      const results = {};
      for (const [year, leagueId] of Object.entries(LEAGUE_IDS)) {
        try {
          const [leagueInfo, leagueRosters, leagueUsers, bracket] = await Promise.all([
            sleeperFetch(`/league/${leagueId}`, true),
            sleeperFetch(`/league/${leagueId}/rosters`, true),
            sleeperFetch(`/league/${leagueId}/users`, true),
            sleeperFetch(`/league/${leagueId}/winners_bracket`).catch(() => []),
          ]);
          // Parse bracket to find championship participants and winner.
          // Sleeper uses p:1 to mark the championship matchup, p:3 for 3rd place, etc.
          // t1/t2 are roster_ids of the participants (populated once bracket resolves).
          // w is the winner's roster_id (populated once the game is played).
          let championRosterId = null;
          let finalistRosterIds = new Set(); // both teams in championship game
          if (bracket && bracket.length) {
            const champMatchup = bracket.find(m => m.p === 1);
            if (champMatchup) {
              if (champMatchup.w) championRosterId = champMatchup.w;
              // t1/t2 are the actual roster_ids once bracket is set
              if (champMatchup.t1) finalistRosterIds.add(champMatchup.t1);
              if (champMatchup.t2) finalistRosterIds.add(champMatchup.t2);
              // If bracket hasn't resolved yet, t1/t2 may be null but w still populated
              if (champMatchup.w) finalistRosterIds.add(champMatchup.w);
              if (champMatchup.l) finalistRosterIds.add(champMatchup.l);
            }
          }
          // Playoff teams count from league settings (default 6)
          const playoffTeams = leagueInfo?.settings?.playoff_teams ?? 6;
          results[year] = { leagueInfo, rosters: leagueRosters, users: leagueUsers, championRosterId, finalistRosterIds, playoffTeams };
        } catch (e) {
          console.error(`Failed to fetch ${year}:`, e);
        }
      }
      setAllSeasonData(results);
      setLoading(false);
    }
    fetchAllSeasons();
  }, []);

  if (loading) return <Spinner label="Loading league history…" />;

  // Build all-time records per owner (keyed by display_name as stable identifier)
  // Build per-season rank for playoff determination
  // Sleeper doesn't expose playoff bracket participants directly — we use
  // final regular season rank (by wins, then PF) vs the playoffTeams cutoff.
  const ownerMap = {};
  for (const [year, data] of Object.entries(allSeasonData)) {
    if (!data) continue;
    const playoffTeams = data.playoffTeams ?? 6;
    // Rank rosters by wins desc, then PF desc
    const rankedRosters = [...data.rosters].sort((a, b) => {
      const wDiff = (b.settings?.wins ?? 0) - (a.settings?.wins ?? 0);
      if (wDiff !== 0) return wDiff;
      const pfA = parseFloat(`${a.settings?.fpts ?? 0}.${a.settings?.fpts_decimal ?? 0}`);
      const pfB = parseFloat(`${b.settings?.fpts ?? 0}.${b.settings?.fpts_decimal ?? 0}`);
      return pfB - pfA;
    });
    const playoffRosterIds = new Set(rankedRosters.slice(0, playoffTeams).map(r => r.roster_id));

    for (const roster of data.rosters) {
      const user = data.users.find(u => String(u.user_id) === String(roster.owner_id));
      if (!user) continue;
      const key = user.display_name;
      const teamName = user.metadata?.team_name || user.display_name;
      if (!ownerMap[key]) ownerMap[key] = { displayName: key, teamName, wins: 0, losses: 0, ties: 0, pf: 0, pa: 0, seasons: [], playoffAppearances: 0, championships: 0 };
      const w = roster.settings?.wins ?? 0;
      const l = roster.settings?.losses ?? 0;
      const t = roster.settings?.ties ?? 0;
      const pf = parseFloat(`${roster.settings?.fpts ?? 0}.${roster.settings?.fpts_decimal ?? 0}`);
      const pa = parseFloat(`${roster.settings?.fpts_against ?? 0}.${roster.settings?.fpts_against_decimal ?? 0}`);
      const madePlayoffs = playoffRosterIds.has(roster.roster_id);
      const isChamp = data.championRosterId != null && roster.roster_id === data.championRosterId;
      ownerMap[key].wins += w;
      ownerMap[key].losses += l;
      ownerMap[key].ties += t;
      ownerMap[key].pf += pf;
      ownerMap[key].pa += pa;
      if (madePlayoffs) ownerMap[key].playoffAppearances += 1;
      if (isChamp) ownerMap[key].championships += 1;
      const isFinalist = (data.finalistRosterIds ?? new Set()).has(roster.roster_id);
      ownerMap[key].seasons.push({ year, wins: w, losses: l, pf, pa, madePlayoffs, isChamp, isFinalist });
    }
  }

  const owners = Object.values(ownerMap).sort((a, b) => {
    const wpA = a.wins / (a.wins + a.losses || 1);
    const wpB = b.wins / (b.wins + b.losses || 1);
    return wpB - wpA;
  });

  // Build H2H matrix from matchups (we'd need to fetch all matchups — for now show per-season summaries)
  const years = Object.keys(LEAGUE_IDS).sort();

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 24 }}>
      <div style={{ display: "flex", gap: 0, borderBottom: `1px solid ${C.border}` }}>
        {[
          { id: "standings", label: "All-Time Records" },
          { id: "seasons", label: "Season by Season" },
        ].map(v => (
          <button key={v.id} onClick={() => setView(v.id)} style={{
            background: "transparent", border: "none",
            borderBottom: `2px solid ${view === v.id ? C.accent : "transparent"}`,
            color: view === v.id ? C.accent : C.muted,
            fontFamily: "'DM Mono', monospace", fontSize: 11, fontWeight: 700,
            letterSpacing: "0.1em", textTransform: "uppercase",
            padding: "10px 18px", cursor: "pointer",
          }}>{v.label}</button>
        ))}
      </div>

      {view === "standings" && (
        <div style={{ ...card, padding: 0, overflow: "hidden" }}>
          <table style={{ width: "100%", borderCollapse: "collapse", fontFamily: "'DM Mono', monospace", fontSize: 12 }}>
            <thead>
              <tr style={{ borderBottom: `1px solid ${C.border}` }}>
                {["Rank", "Manager", "W", "L", "Win%", "Total PF", "Total PA", "Playoffs", "🏆"].map(h => (
                  <th key={h} style={{ padding: "10px 16px", color: C.muted, fontWeight: 600, letterSpacing: "0.08em", textAlign: h === "Manager" ? "left" : "right", fontSize: 10, textTransform: "uppercase" }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {owners.map((o, i) => {
                const wp = ((o.wins / (o.wins + o.losses || 1)) * 100).toFixed(1);
                return (
                  <tr key={o.displayName} style={{ borderBottom: `1px solid ${C.border}`, cursor: "pointer" }}
                    onMouseEnter={e => e.currentTarget.style.background = C.surfaceHigh}
                    onMouseLeave={e => e.currentTarget.style.background = "transparent"}
                    onClick={() => setSelectedTeam(selectedTeam === o.displayName ? null : o.displayName)}>
                    <td style={{ padding: "10px 16px", color: C.muted, textAlign: "right" }}>{i + 1}</td>
                    <td style={{ padding: "10px 16px", color: C.text, fontWeight: 600 }}>
                      {o.teamName}
                      <div style={{ fontSize: 10, color: C.muted, fontWeight: 400 }}>@{o.displayName}</div>
                    </td>
                    <td style={{ padding: "10px 16px", color: C.green, textAlign: "right" }}>{o.wins}</td>
                    <td style={{ padding: "10px 16px", color: C.red, textAlign: "right" }}>{o.losses}</td>
                    <td style={{ padding: "10px 16px", color: C.accent, textAlign: "right", fontWeight: 700 }}>{wp}%</td>
                    <td style={{ padding: "10px 16px", color: C.text, textAlign: "right" }}>{o.pf.toFixed(1)}</td>
                    <td style={{ padding: "10px 16px", color: C.muted, textAlign: "right" }}>{o.pa.toFixed(1)}</td>
                    <td style={{ padding: "10px 16px", color: C.blue, textAlign: "right", fontWeight: 600 }}>{o.playoffAppearances}</td>
                    <td style={{ padding: "10px 16px", textAlign: "right" }}>
                      {o.championships > 0
                        ? <span style={{ fontSize: 14 }}>{"👑".repeat(o.championships)}</span>
                        : <span style={{ color: C.muted }}>—</span>}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
          {selectedTeam && (() => {
            const o = ownerMap[selectedTeam];
            if (!o) return null;
            return (
              <div style={{ padding: "20px 24px", borderTop: `1px solid ${C.border}`, background: C.surfaceHigh }}>
                <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 18, fontWeight: 700, color: C.accent, marginBottom: 12 }}>{o.teamName} — Year by Year</div>
                <div style={{ display: "flex", gap: 12, flexWrap: "wrap" }}>
                  {o.seasons.map(s => (
                    <div key={s.year} style={{ ...statBox, minWidth: 120, textAlign: "center" }}>
                      <div style={{ fontSize: 10, color: C.muted, fontFamily: "'DM Mono', monospace", letterSpacing: "0.08em" }}>{s.year}</div>
                      <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 20, fontWeight: 700, color: C.text, marginTop: 4 }}>{s.wins}–{s.losses}</div>
                      <div style={{ fontSize: 10, color: C.muted, fontFamily: "'DM Mono', monospace" }}>{s.pf.toFixed(1)} PF</div>
                    </div>
                  ))}
                </div>
              </div>
            );
          })()}
        </div>
      )}

      {view === "seasons" && (
        <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
          {years.map(year => {
            const data = allSeasonData[year];
            if (!data) return <div key={year} style={{ color: C.muted, fontFamily: "'DM Mono', monospace", fontSize: 12 }}>No data for {year}</div>;
            const sorted = [...data.rosters].sort((a, b) => (b.settings?.wins ?? 0) - (a.settings?.wins ?? 0));
            return (
              <div key={year}>
                <SectionHeader label={`${year} Season`} />
                <div style={{ ...card, padding: 0, overflow: "hidden" }}>
                  <table style={{ width: "100%", borderCollapse: "collapse", fontFamily: "'DM Mono', monospace", fontSize: 12 }}>
                    <thead>
                      <tr style={{ borderBottom: `1px solid ${C.border}` }}>
                        {["#", "Team", "W", "L", "PF", "PA"].map(h => (
                          <th key={h} style={{ padding: "9px 14px", color: C.muted, fontWeight: 600, textAlign: h === "Team" ? "left" : "right", fontSize: 10, textTransform: "uppercase", letterSpacing: "0.08em" }}>{h}</th>
                        ))}
                      </tr>
                    </thead>
                    <tbody>
                      {sorted.map((roster, i) => {
                        const u = data.users.find(u => String(u.user_id) === String(roster.owner_id));
                        const name = u?.metadata?.team_name || u?.display_name || "Unknown";
                        const pf = parseFloat(`${roster.settings?.fpts ?? 0}.${roster.settings?.fpts_decimal ?? 0}`).toFixed(1);
                        const pa = parseFloat(`${roster.settings?.fpts_against ?? 0}.${roster.settings?.fpts_against_decimal ?? 0}`).toFixed(1);
                        const playoffTeams = data.playoffTeams ?? 6;
                        // Rank is i+1 in already-sorted array
                        const madePlayoffs = i < playoffTeams;
                        // Championship participants derived from bracket p:1 matchup
                        const finalists = data.finalistRosterIds ?? new Set();
                        const inChampionship = finalists.size > 0
                          ? finalists.has(roster.roster_id)
                          : false; // don't guess if bracket data unavailable
                        const isChamp = data.championRosterId != null && roster.roster_id === data.championRosterId;
                        // For current active season: no championship shading (playoffs may not have happened)
                        const isCurrentSeason = year === CURRENT_YEAR.toString();
                        // Row background: champion = warm gold tint, championship = light green tint, playoff = very subtle
                        // For active season: skip championship tint, only show playoff tint
                        const rowBg = isChamp
                          ? "rgba(212,168,71,0.10)"
                          : (!isCurrentSeason && inChampionship)
                          ? C.accentLight
                          : madePlayoffs
                          ? "rgba(26,92,42,0.04)"
                          : "transparent";
                        return (
                          <tr key={roster.roster_id}
                            style={{ borderBottom: `1px solid ${C.border}`, background: rowBg, transition: "background 0.1s" }}
                            onMouseEnter={e => e.currentTarget.style.background = C.surfaceHigh}
                            onMouseLeave={e => e.currentTarget.style.background = rowBg}>
                            <td style={{ padding: "9px 14px", color: C.muted, textAlign: "right" }}>{i + 1}</td>
                            <td style={{ padding: "9px 14px", color: isChamp ? "#9a6800" : C.text, fontWeight: isChamp ? 700 : 400 }}>
                              {isChamp && <span style={{ marginRight: 6 }}>👑</span>}
                              {name}
                              {!isCurrentSeason && inChampionship && !isChamp && <span style={{ marginLeft: 6, fontSize: 9, color: C.accent, fontFamily: "'DM Mono', monospace", letterSpacing: "0.06em", textTransform: "uppercase" }}>Final</span>}
                              {madePlayoffs && !inChampionship && <span style={{ marginLeft: 6, fontSize: 9, color: C.muted, fontFamily: "'DM Mono', monospace", letterSpacing: "0.06em", textTransform: "uppercase" }}>Playoff</span>}
                            </td>
                            <td style={{ padding: "9px 14px", color: C.green, textAlign: "right" }}>{roster.settings?.wins ?? 0}</td>
                            <td style={{ padding: "9px 14px", color: C.red, textAlign: "right" }}>{roster.settings?.losses ?? 0}</td>
                            <td style={{ padding: "9px 14px", color: C.text, textAlign: "right" }}>{pf}</td>
                            <td style={{ padding: "9px 14px", color: C.muted, textAlign: "right" }}>{pa}</td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
                <div style={{ padding: "8px 14px", borderTop: `1px solid ${C.border}`, display: "flex", gap: 16, background: C.surfaceHigh }}>
                  {[
                    ["rgba(212,168,71,0.10)", "👑 Champion"],
                    [C.accentLight, "Championship Game"],
                    ["rgba(26,92,42,0.04)", "Playoff"],
                  ].map(([bg, label]) => (
                    <div key={label} style={{ display: "flex", alignItems: "center", gap: 6, fontSize: 10, fontFamily: "'DM Mono', monospace", color: C.muted }}>
                      <div style={{ width: 12, height: 12, background: bg, border: `1px solid ${C.border}`, borderRadius: 2 }} />
                      {label}
                    </div>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

// ── Shared helpers ────────────────────────────────────────────────────────────
function SectionHeader({ label }) {
  return (
    <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 12 }}>
      <div style={{ fontSize: 10, fontFamily: "'DM Mono', monospace", fontWeight: 700, color: C.accent, letterSpacing: "0.15em", textTransform: "uppercase" }}>{label}</div>
      <div style={{ flex: 1, height: 1, background: C.border }} />
    </div>
  );
}

// ── APP ROOT ──────────────────────────────────────────────────────────────────
export default function BGMApp() {
  const [tab, setTab] = useState("home");
  const [session, setSession] = useState(null);
  const [showAuth, setShowAuth] = useState(false);

  // Sleeper data
  const [leagueData, setLeagueData] = useState(null);
  const [rosters, setRosters] = useState([]);
  const [users, setUsers] = useState([]);
  const [allPlayers, setAllPlayers] = useState(null);
  const [fcPlayers, setFcPlayers] = useState(null);   // FantasyCalc all-player data
  const [nflState, setNflState] = useState(null);
  const [dataLoaded, setDataLoaded] = useState(false);

  // Auth
  useEffect(() => {
    supabase.auth.getSession().then(({ data: { session } }) => setSession(session));
    const { data: { subscription } } = supabase.auth.onAuthStateChange((_e, s) => setSession(s));
    return () => subscription.unsubscribe();
  }, []);

  // Load Sleeper data once authed
  // Split into two fetches:
  //   1. Roster/league data — no-cache so lineup changes in Sleeper show immediately on reload
  //   2. Player database + FantasyCalc — large/slow, browser cache is fine
  useEffect(() => {
    if (!session) return;
    async function loadRosterData() {
      try {
        const [ld, rs, us, ns] = await Promise.all([
          sleeperFetch(`/league/${CURRENT_LEAGUE_ID}`, true),
          sleeperFetch(`/league/${CURRENT_LEAGUE_ID}/rosters`, true),
          sleeperFetch(`/league/${CURRENT_LEAGUE_ID}/users`, true),
          sleeperFetch(`/state/nfl`, true),
        ]);
        setLeagueData(ld);
        setRosters(rs);
        setUsers(us);
        setNflState(ns);
      } catch (e) {
        console.error("Failed to load roster data:", e);
      }
    }

    async function loadPlayerData() {
      try {
        const [players, fcRaw] = await Promise.all([
          sleeperFetch(`/players/nfl`),   // large — let browser cache this
          fetch("https://api.fantasycalc.com/values/current?isDynasty=true&numQbs=1&numTeams=12&ppr=0.5")
            .then(r => r.json()).catch(() => []),
        ]);
        setAllPlayers(players);
        const fcMap = {};
        const relevant = ["QB", "RB", "WR", "TE"];
        for (const d of (fcRaw || [])) {
          if (!d.player?.sleeperId || !relevant.includes(d.player?.position)) continue;
          fcMap[d.player.sleeperId] = {
            fcValue: d.value,
            fcOverallRank: d.overallRank,
            fcPosRank: d.positionRank,
            fcPos: d.player.position,
            fcName: d.player.name,
            fcTeam: d.player.maybeTeam || null,
            fcAge: d.player.maybeAge ? parseFloat(d.player.maybeAge).toFixed(1) : null,
            fcYoe: d.player.maybeYoe,
            fcCollege: d.player.maybeCollege || null,
          };
        }
        setFcPlayers(fcMap);
      } catch (e) {
        console.error("Failed to load player data:", e);
      } finally {
        setDataLoaded(true);
      }
    }

    // Run both in parallel — roster data is fast, player data is slow
    Promise.all([loadRosterData(), loadPlayerData()]);
  }, [session]);

  const myUser = users.find(u => u.display_name === SLEEPER_USERNAME);
  const myRoster = myUser ? rosters.find(r => String(r.owner_id) === String(myUser.user_id)) : null;

  const tabs = [
    { id: "home", label: "Home" },
    { id: "roster", label: "Roster" },
    { id: "watchlist", label: "Watch List" },
    { id: "rookiedraft", label: "Rookie Draft" },
    { id: "history", label: "League History" },
  ];

  return (
    <div style={{ fontFamily: "'DM Mono', monospace", background: C.bg, minHeight: "100vh", color: C.text, position: "relative" }}>
      <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Barlow+Condensed:wght@400;600;700;800&display=swap" rel="stylesheet" />
      <style>{`
        *, *::before, *::after { box-sizing: border-box; }
        html, body, #root { margin: 0; padding: 0; width: 100%; }
        @keyframes spin { to { transform: rotate(360deg); } }
        select option { background: #ffffff; color: #0f2e15; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: ${C.bg}; }
        ::-webkit-scrollbar-thumb { background: ${C.border}; border-radius: 3px; }
        input::placeholder { color: ${C.muted}; }
        textarea::placeholder { color: ${C.muted}; }
      `}</style>
      {/* Faded logo watermark — fixed, behind all content */}
      {/* mix-blend-mode: multiply makes white pixels transparent on light backgrounds */}
      <img
        src="/BGM_Logo.png"
        alt=""
        aria-hidden="true"
        style={{
          position: "fixed", top: "50%", left: "50%",
          transform: "translate(-50%, -50%)",
          width: "65vw", maxWidth: 680,
          pointerEvents: "none", zIndex: 0,
          opacity: 0.07,
          mixBlendMode: "multiply",
          userSelect: "none",
        }}
      />

      {showAuth && <AuthModal onClose={() => setShowAuth(false)} />}

      {/* Header */}
      <div style={{ borderBottom: `1px solid ${C.border}`, background: C.white, padding: "0 4vw", display: "flex", alignItems: "center", justifyContent: "space-between", height: 58, position: "sticky", top: 0, zIndex: 100, boxShadow: "0 1px 4px rgba(26,92,42,0.07)" }}>
        <div style={{ display: "flex", alignItems: "center", gap: 28 }}>
          {/* Wordmark + slogan */}
          <div style={{ display: "flex", flexDirection: "column", justifyContent: "center", gap: 1, borderRight: `1px solid ${C.border}`, paddingRight: 24 }}>
            <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 20, fontWeight: 800, color: C.accent, letterSpacing: "0.04em", textTransform: "uppercase", lineHeight: 1.1 }}>
              Big Green Machine
            </div>
            <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 9, fontWeight: 400, color: C.muted, letterSpacing: "0.13em", textTransform: "uppercase", lineHeight: 1 }}>
              Nobody Bigger Than The Machine
            </div>
          </div>
          {session && (
            <div style={{ display: "flex", gap: 0, overflowX: "auto" }}>
              {tabs.map(t => (
                <button key={t.id} onClick={() => setTab(t.id)} style={tabBtn(tab === t.id)}>{t.label}</button>
              ))}
            </div>
          )}
        </div>
        <div>
          {session ? (
            <button onClick={() => supabase.auth.signOut()} style={{ background: "transparent", border: `1px solid ${C.border}`, color: C.muted, borderRadius: 4, padding: "5px 14px", fontSize: 11, fontFamily: "'DM Mono', monospace", cursor: "pointer", letterSpacing: "0.06em" }}>Sign Out</button>
          ) : (
            <button onClick={() => setShowAuth(true)} style={{ background: C.accent, color: C.white, border: "none", borderRadius: 4, padding: "7px 18px", fontSize: 12, fontWeight: 700, fontFamily: "'Barlow Condensed', sans-serif", cursor: "pointer", letterSpacing: "0.1em", textTransform: "uppercase" }}>Log In</button>
          )}
        </div>
      </div>

      {/* Content */}
      <div style={{ maxWidth: 1100, margin: "0 auto", padding: "32px 4vw", position: "relative", zIndex: 1 }}>
        {!session ? (
          <div style={{ textAlign: "center", padding: "120px 0" }}>
            <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: 72, fontWeight: 800, color: C.accent, letterSpacing: "-0.01em", lineHeight: 1 }}>Big Green Machine</div>
            <div style={{ fontFamily: "'DM Mono', monospace", fontSize: 11, color: C.muted, letterSpacing: "0.2em", marginTop: 12, textTransform: "uppercase" }}>Nobody Bigger Than The Machine</div>
            <div style={{ width: 48, height: 2, background: C.accent, margin: "20px auto", borderRadius: 2, opacity: 0.4 }} />
            <div style={{ fontSize: 12, fontFamily: "'DM Mono', monospace", color: C.muted, letterSpacing: "0.12em", textTransform: "uppercase" }}>Dynasty Franchise Headquarters</div>
            <button onClick={() => setShowAuth(true)} style={{ background: C.accent, color: C.white, border: "none", borderRadius: 4, padding: "13px 36px", fontSize: 13, fontWeight: 700, fontFamily: "'Barlow Condensed', sans-serif", cursor: "pointer", letterSpacing: "0.12em", textTransform: "uppercase", marginTop: 32, boxShadow: "0 2px 12px rgba(26,92,42,0.18)" }}>Enter</button>
          </div>
        ) : !dataLoaded ? (
          <Spinner label="Pulling franchise data from Sleeper…" />
        ) : (
          <>
            {tab === "home" && <HomeTab leagueData={leagueData} rosters={rosters} users={users} myRoster={myRoster} myUser={myUser} nflState={nflState} />}
            {tab === "roster" && <RosterTab myRoster={myRoster} allPlayers={allPlayers} fcPlayers={fcPlayers} nflState={nflState} rosters={rosters} users={users} />}
            {tab === "watchlist" && <WatchListTab allPlayers={allPlayers} fcPlayers={fcPlayers} myRoster={myRoster} />}
            {tab === "rookiedraft" && <RookieDraftTab allPlayers={allPlayers} myRoster={myRoster} rosters={rosters} users={users} />}
            {tab === "history" && <LeagueHistoryTab rosters={rosters} users={users} />}
          </>
        )}
      </div>
    </div>
  );
}
